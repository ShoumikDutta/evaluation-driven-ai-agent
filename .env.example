# Copy this file to .env for local demos.
# Never commit real API keys.

# Default: mock judge. For one provider, use:
# JUDGE_PROVIDER=mock
# JUDGE_PROVIDER=openai
# JUDGE_PROVIDER=ollama
# JUDGE_PROVIDER=gemini
# JUDGE_PROVIDER=groq
# JUDGE_PROVIDER=openrouter

# Judge panel: comma-separated provider:model entries.
# Keep mock in the panel if you want a deterministic baseline vote.
JUDGE_PANEL=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter
OPENROUTER_API_KEY=
# Pick a free model ID from OpenRouter and put the exact ID here.
OPENROUTER_MODEL=

# Ollama local judge, no API key needed.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
